<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>PTIT Social Chat</display-name>

    <!-- Welcome page -->
    <welcome-file-list>
        <welcome-file>LoginServlet</welcome-file>
    </welcome-file-list>

    <!-- ============================================================ -->
    <!--  SERVLET DECLARATIONS                                        -->
    <!-- ============================================================ -->

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.ptit.socialchat.servlet.LoginServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.ptit.socialchat.servlet.RegisterServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.ptit.socialchat.servlet.LogoutServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>HomeServlet</servlet-name>
        <servlet-class>com.ptit.socialchat.servlet.HomeServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>PostServlet</servlet-name>
        <servlet-class>com.ptit.socialchat.servlet.PostServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>FriendServlet</servlet-name>
        <servlet-class>com.ptit.socialchat.servlet.FriendServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>ChatServlet</servlet-name>
        <servlet-class>com.ptit.socialchat.servlet.ChatServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>ProfileServlet</servlet-name>
        <servlet-class>com.ptit.socialchat.servlet.ProfileServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>AdminServlet</servlet-name>
        <servlet-class>com.ptit.socialchat.servlet.AdminServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>SearchServlet</servlet-name>
        <servlet-class>com.ptit.socialchat.servlet.SearchServlet</servlet-class>
    </servlet>

    <!-- ============================================================ -->
    <!--  SERVLET MAPPINGS                                            -->
    <!-- ============================================================ -->

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/RegisterServlet</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/LogoutServlet</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>HomeServlet</servlet-name>
        <url-pattern>/HomeServlet</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>PostServlet</servlet-name>
        <url-pattern>/PostServlet</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>FriendServlet</servlet-name>
        <url-pattern>/FriendServlet</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>ChatServlet</servlet-name>
        <url-pattern>/ChatServlet</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>ProfileServlet</servlet-name>
        <url-pattern>/ProfileServlet</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>AdminServlet</servlet-name>
        <url-pattern>/AdminServlet</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>SearchServlet</servlet-name>
        <url-pattern>/SearchServlet</url-pattern>
    </servlet-mapping>

    <!-- Session timeout: 30 minutes -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- Character encoding filter -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.ptit.socialchat.filter.EncodingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Auth filter - protect secured pages -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.ptit.socialchat.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/HomeServlet</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/PostServlet</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/FriendServlet</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/ChatServlet</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/ProfileServlet</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/AdminServlet</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/SearchServlet</url-pattern>
    </filter-mapping>

</web-app>
